{
  "$schema": "https://angular.io/config/angular.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "fleet-dashboard": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/fleet-dashboard",
            "index": "src/index.html",
            "main": "src/main.ts",
            "polyfills": "src/polyfills.ts",
            "tsConfig": "tsconfig.app.json",
            "assets": [
              "src/favicon.ico",
              "src/assets"
            ],
            "styles": [
              "src/styles.css"
            ],
            "scripts": []
          }
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "browserTarget": "fleet-dashboard:build"
          }
        }
      }
    }
  },
  "defaultProject": "fleet-dashboard",
  "cli": {
    "analytics": false
  }
}
